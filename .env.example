# Database Configuration
POSTGRES_USER=ekai
POSTGRES_PASSWORD=ekai_dev_password
POSTGRES_DB=ekai_dev
DATABASE_URL=postgresql://ekai:ekai_dev_password@localhost:5432/ekai_dev

# JWT Authentication
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRY=7d

# OTP Configuration
OTP_EXPIRY_MINUTES=5

# APAAR Integration
APAAR_API_URL=https://api.apaar.education.gov.in/v1
APAAR_API_KEY=demo-key

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Client Configuration
VITE_API_URL=http://localhost:5000

# Email Service (Optional)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-password
MAIL_FROM=noreply@ekai.local

# SMS Service (Optional)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-account-sid
SMS_AUTH_TOKEN=your-auth-token
SMS_FROM_NUMBER=+1234567890

# AWS Configuration (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=ekai-uploads

# Logging
LOG_LEVEL=debug
